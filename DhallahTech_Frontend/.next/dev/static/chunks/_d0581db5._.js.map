"use client";

import React from 'react';
import { useRouter } from "next/navigation";

// ثوابت وشعارات المنصة 
const splashLogoPath = "/image-removebg-preview.png";      
const headerLogoPath = "/logo-icon.png";    
const placeholderLogo = "https://placehold.co/600x200/ffffff/5E3085?text=ضالتك";

export default function App() {
  const router = useRouter();

  return (
     <div className="min-h-screen bg-[#FAF9FC] bg-gradient-to-b from-white via-[#F7F4FA] to-[#F1EDF5] flex flex-col items-center overflow-x-hidden text-right select-none text-[#1E112C] relative" dir="rtl">
      
      {/* 🔴 استدعاء الخطوط بشكل قياسي وآمن متوافق مع Next.js */}
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossOrigin="anonymous" />
      <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=El+Messiri:wght@600;700&display=swap" rel="stylesheet" />

      {/* 🔮 1. التموجات والمنحنيات الانسيابية البرمجية (Abstract Luxury Fluid Waves) لكسر جمود الألوان الفاتحة */}
      <div className="absolute top-0 right-0 w-full max-w-[500px] md:max-w-[800px] opacity-[0.25] pointer-events-none z-0 select-none">
        <svg viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg" className="w-full h-auto transform rotate-180 scale-x-[-1]">
          <defs>
            <linearGradient id="gradientWave" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stopColor="#5E3085" stopOpacity="0.8" />
              <stop offset="50%" stopColor="#A482C7" stopOpacity="0.4" />
              <stop offset="100%" stopColor="#FAF9FC" stopOpacity="0" />
            </linearGradient>
          </defs>
          <path fill="url(#gradientWave)" d="M0,200 C300,100 400,400 700,250 C900,150 950,300 1000,200 L1000,0 L0,0 Z" />
          <path fill="url(#gradientWave)" opacity="0.5" d="M0,250 C250,180 350,450 650,300 C850,200 900,350 1000,280 L1000,0 L0,0 Z" />
        </svg>
      </div>

      <div className="absolute top-[30%] left-0 w-full max-w-[400px] md:max-w-[700px] opacity-[0.18] pointer-events-none z-0 select-none">
        <svg viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg" className="w-full h-auto">
          <path fill="url(#gradientWave)" d="M0,150 C200,300 400,100 700,300 C900,400 950,200 1000,350 L1000,0 L0,0 Z" />
        </svg>
      </div>

      {/* الهالات الضوئية البنفسجية خلف الشعار لتعطي عمقاً ثلاثي الأبعاد كما في الصور المقترحة */}
      <div className="absolute top-[12%] left-1/2 -translate-x-1/2 w-[400px] h-[400px] rounded-full bg-[#5E3085]/5 blur-[90px] pointer-events-none z-0" />

      {/* 🔹 2. شريط الإكسنت العلوي النحيف بلون موف متناسق مع الشعار لمنح فخامة فورية */}
      <div className="w-full h-2 bg-gradient-to-r from-[#5E3085] via-[#7B42A8] to-[#4A2669] sticky top-0 z-50" />

      {/* 🔹 3. الـ Navbar المطور بزجاجية نقية مندمجة */}
      <header className="w-full px-6 md:px-12 py-4 flex items-center bg-white/60 backdrop-blur-md border-b border-purple-100/30 sticky top-2 z-50 shadow-[0_2px_20px_-10px_rgba(94,48,133,0.05)]">
        <img
          src={headerLogoPath}
          alt="Logo"
          className="h-9 w-auto object-contain cursor-pointer transition-all duration-300 hover:scale-105"
          onClick={() => router.push("/")}
        />
        <div className="flex-1" />
        
        <div className="flex items-center gap-2 sm:gap-4">
          <button
            onClick={() => router.push("/guest")}
            className="text-gray-600 hover:text-gray-900 text-xs sm:text-sm font-bold transition-all duration-300 px-4 py-2 rounded-xl hover:bg-gray-100/70 flex items-center gap-2"
            style={{ fontFamily: "'Cairo', sans-serif" }}
          >
            <GuestIcon />
            <span className="hidden xs:inline">الدخول كزائر</span>
          </button>
          
          <button
            onClick={() => router.push("/signup")}
            className="text-[#5E3085] hover:text-[#4A2669] text-xs sm:text-sm font-bold transition-all duration-300 px-4 py-2 rounded-xl hover:bg-purple-50 flex items-center gap-2"
            style={{ fontFamily: "'Cairo', sans-serif" }}
          >
            <RegisterIcon />
            <span className="hidden xs:inline">إنشاء حساب</span>
          </button>

          <button
            onClick={() => router.push("/login")}
            className="bg-[#5E3085] text-white px-6 py-2.5 rounded-xl text-xs font-bold shadow-md hover:bg-[#4A2669] hover:shadow-purple-900/20 transition-all duration-300 hover:scale-105 active:scale-95 flex items-center gap-2"
            style={{ fontFamily: "'Cairo', sans-serif" }}
          >
            <LoginIcon />
            <span>تسجيل الدخول</span>
          </button>
        </div>
      </header>

      {/* 🔹 المحتوى الرئيسي للموقع */}
      <main className="w-full flex-1 flex flex-col items-center relative z-10">
        <SplashScreen router={router} />
      </main>

      {/* 🔹 الفوتر المشرق والنظيف */}
      <footer className="w-full py-10 text-center bg-white border-t border-gray-100 relative z-30">
        <p className="text-gray-400 text-xs font-bold tracking-widest uppercase" style={{ fontFamily: "'Cairo', sans-serif" }}>
          جميع الحقوق محفوظة © منصة ضالتك 2026
        </p>
      </footer>
    </div>
  );
}

const SplashScreen = ({ router }) => (
  <div className="w-full flex flex-col items-center text-center">
    
    {/* 💜 4. منطقة الـ Hero Section (الشعار الكبير في السنتر يطفو فوق التموجات العائمة) */}
    <div className="w-full pt-16 pb-12 px-6 md:px-12 relative flex flex-col items-center">
      <div className="max-w-4xl mx-auto flex flex-col items-center justify-center gap-6 relative z-10 w-full text-center">
        
        {/* الشعار الكبير يتوسط صدارة الصفحة ينسجم مع حركة الموف التموجية الخلفية */}
        <div className="mb-2 transition-all duration-500 hover:scale-[1.01] flex items-center justify-center w-full max-w-[320px] md:max-w-[360px]">
          <img 
            src={splashLogoPath} 
            onError={(e) => { e.currentTarget.src = placeholderLogo; }}
            alt="DhallaTec Logo" 
            className="w-full h-auto object-contain drop-shadow-[0_10px_30px_rgba(94,48,133,0.05)]" 
          />
        </div>

        {/* السلوقن (العنوان الرئيسي) بتأثير الظهور الصاعد الاحترافي السلس */}
        <div className="py-1 px-4 flex items-center justify-center w-full max-w-3xl mx-auto overflow-visible whitespace-normal">
          <h1 
            className="text-4xl md:text-5xl font-black leading-tight text-[#1A0B2E] text-center opacity-0 transform translate-y-6 animate-[textReveal_1s_cubic-bezier(0.16,1,0.3,1)_0.1s_forwards] block w-full tracking-tight" 
            style={{ fontFamily: "'El Messiri', sans-serif" }}
          >
            ضالتك.. تعود بكل سهولة
          </h1>
        </div>
        
        {/* الكلام (النص الوصفي) بلون مريح ومقروء */}
        <p 
          className="text-gray-600 text-sm md:text-base leading-relaxed max-w-2xl mx-auto opacity-0 transform translate-y-4 animate-[textReveal_1s_cubic-bezier(0.16,1,0.3,1)_0.4s_forwards]" 
          style={{ fontFamily: "'Cairo', sans-serif" }}
        >
          منصة رقمية ذكية تعنى بإعادة المفقودات لذويها بسرعة ودقة، عبر نظام تطابق مدعوم بالذكاء الاصطناعي، تربط الأفراد بالجهات المحلية في منطقة مكة المكرمة ضمن تجربة موثوقة وسلسة تعزز جودة الحياة وتدعم مستهدفات رؤية المملكة العربية السعودية 2030.
        </p>
      </div>
    </div>

    {/* 🟢 5. حاوية رحلة استعادة ضالتك (الحاوية البيضاء العائمة الموزونة بظلالها المودرن) */}
    <div className="w-full max-w-5xl px-6 md:px-12 mb-20 relative mt-6 flex flex-col items-center">
      <div className="w-full bg-white rounded-[32px] border border-purple-100/40 shadow-[0_20px_50px_rgba(94,48,133,0.04)] p-6 md:p-10 relative z-20 flex flex-col items-center">
        
        {/* شريط العنوان الزجاجي الفخم الممتد بكامل الديف */}
        <div className="w-full bg-gradient-to-r from-purple-50/10 via-purple-100/40 to-purple-50/10 py-5 mb-12 border-y border-purple-500/10 backdrop-blur-sm flex items-center justify-center rounded-xl">
          <h2 className="text-[#250A3F] text-2xl md:text-3xl font-black text-center relative tracking-wide flex items-center gap-3" style={{ fontFamily: "'El Messiri', sans-serif" }}>
            <span className="w-2 h-2 rounded-full bg-[#5E3085] block animate-pulse" />
            رحلة استعادة ضالتك
            <span className="w-2 h-2 rounded-full bg-[#5E3085] block animate-pulse" />
          </h2>
        </div>

        <div className="w-full flex flex-col lg:flex-row items-center justify-between gap-10">
          {/* جهة اليمين: كروت الميزات مصفوفة عمودياً بنقاء تام */}
          <div className="flex-1 flex flex-col gap-6 w-full text-right">
            <FeatureCard
              number="1"
              title="الإبلاغ عن المفقود"
              desc="قم بتسجيل تقرير مفصل عن العنصر المفقود مع الصور والوصف الدقيق لمطابقته الفورية الإحترافية عبر الواجهة الذكية."
              icon={<FileIcon />}
            />
            <FeatureCard
              number="2"
              title="المطابقة الذكية"
              desc="يقوم النظام تلقائياً بمطابقة المفقودات مع العناصر الموجودة باستخدام تقنيات الذكاء الاصطناعي الفائقة."
              icon={<SparkleIcon />}
            />
            <FeatureCard
              number="3"
              title="التحقق من الملكية"
              desc="يتم التحقق من أحقية ملكية العنصر عبر أسئلة برمجية ذكية وسرية قبل تسليمه كاملاً لصاحبه الأصلي."
              icon={<BoxIcon />}
            />
          </div>

          {/* جهة اليسار: حاوية عائمة مخصصة ومحجوزة بالكامل لإضافة صورتكِ الخاصة بها بسلاسة */}
          <div className="flex-1 w-full max-w-md bg-gradient-to-tr from-purple-50/10 to-white p-4 rounded-[28px] border border-purple-100/30 flex flex-col items-center shadow-[inset_0_4px_20px_rgba(0,0,0,0.01)] relative overflow-hidden">
            <div className="bg-white p-2 rounded-[22px] shadow-[0_10px_35px_rgba(94,48,133,0.03)] border border-gray-100 overflow-hidden w-full aspect-[4/3] relative">
              <img 
                src="/your-custom-image.png" 
                alt="عمليات منصة ضالتك"
                className="w-full h-full object-cover rounded-[16px]"
                onError={(e) => { 
                  e.currentTarget.src = "https://placehold.co/600x450/ffffff/5E3085?text=ضع+صورتك+هنا"; 
                }}
              />
            </div>
          </div>
        </div>

        {/* بطاقة الدعم الفني السريعة مدمجة بشكل عائم أسفل كتل العمليات */}
        <div className="w-full mt-12 bg-purple-50/40 rounded-2xl p-5 border border-purple-100/40 flex flex-col sm:flex-row items-center justify-between gap-4 text-right">
          <div className="flex items-center gap-4">
            <div className="w-12 h-12 bg-white text-[#5E3085] rounded-xl flex items-center justify-center shadow-sm shrink-0">
              <ContactIcon />
            </div>
            <p className="text-gray-600 text-sm font-semibold" style={{ fontFamily: "'Cairo', sans-serif" }}>لديك استفسار أو واجهت مشكلة؟ فريق دعم ضالتك متواجد لخدمتك دائماً.</p>
          </div>
          <button 
            onClick={() => window.location.href = 'mailto:support@dhallatech.com'}
            className="bg-[#5E3085] text-white px-7 py-2.5 rounded-full text-xs font-bold shadow-md hover:bg-[#4A2669] transition-all duration-300 hover:scale-105"
            style={{ fontFamily: "'Cairo', sans-serif" }}
          >
            تواصل معنا
          </button>
        </div>

      </div>
    </div>

    {/* 🟢 6. مقطع "نطاق التغطية والمقرات" منفصل بالأسفل بفاصل زجاجي نيون أنيق */}
    <div className="w-full flex flex-col items-center relative z-20">
      
      {/* شريط فاصل ممتد متناسق 100% مع الفاصل الأول */}
      <div className="w-screen bg-gradient-to-r from-purple-50/10 via-purple-100/50 to-purple-50/10 py-6 mb-12 border-y border-purple-500/10 backdrop-blur-sm flex items-center justify-center">
        <h2 className="text-[#250A3F] text-2xl md:text-3xl font-black text-center relative tracking-wide flex items-center gap-3" style={{ fontFamily: "'El Messiri', sans-serif" }}>
          <span className="w-2 h-2 rounded-full bg-[#5E3085] block animate-pulse" />
          نطاق التغطية والمقرات
          <span className="w-2 h-2 rounded-full bg-[#5E3085] block animate-pulse" />
        </h2>
      </div>

      {/* حاوية الخريطة المستقلة بالخلفية البيضاء الموزونة هندسياً بمطابقة كاملة للقسم الأول */}
      <div className="w-full max-w-5xl px-6 md:px-12 mb-24">
        <div className="w-full text-center bg-white p-6 md:p-10 rounded-[32px] border border-purple-100/40 shadow-[0_20px_50px_rgba(94,48,133,0.04)] flex flex-col items-center">
          
          <p className="text-[#5E3085] text-xs md:text-sm font-bold mb-5 tracking-wide bg-purple-50 inline-block px-5 py-2 rounded-full border border-purple-100 shadow-sm" style={{ fontFamily: "'Cairo', sans-serif" }}>
            تعرف على مكاتب المفقودات المسجلة بالنظام
          </p>
          
          <p className="text-gray-600 text-sm md:text-base mb-8 max-w-xl mx-auto leading-relaxed font-semibold" style={{ fontFamily: "'Cairo', sans-serif" }}>
            يمكنك تصفح الخريطة التفاعلية والذكية للتعرف على نقاط الاستلام والتسليم المعتمدة لمنصة ضالتك في منطقة مكة المكرمة.
          </p>
          
          {/* حاوية الخريطة الاحترافية النظيفة المستقلة */}
          <div className="bg-white p-2 rounded-[26px] shadow-sm border border-gray-200 overflow-hidden w-full aspect-[16/9] relative">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d237684.5513560662!2d39.70678077749811!3d21.43254924164805!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x15c21b4f8107d79d%3A0x87d6cbbb2118c4b2!2sMakkah!5e0!3m2!1sen!2ssa!4v1717200000000!5m2!1sen!2ssa" 
              className="absolute w-full h-full border-0 rounded-[18px] top-0 left-0"
              allowFullScreen="" 
              loading="lazy" 
              referrerPolicy="no-referrer-when-downgrade"
            />
          </div>
        </div>
      </div>
    </div>

    {/* 🔴 ستايلات حركة الـ Reveal الرشيقة */}
    <style jsx global>{`
      @keyframes textReveal {
        0% {
          opacity: 0;
          transform: translateY(20px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }
    `}</style>

  </div>
);

{/* مكون كرت الميزات المطور بأسلوب الـ SaaS الاحترافي النظيف */}
const FeatureCard = ({ number, title, desc, icon }) => (
  <div className="bg-white p-5 md:p-6 rounded-[20px] shadow-[0_4px_25px_rgba(0,0,0,0.01)] border border-gray-100 text-right w-full transition-all duration-500 hover:shadow-[0_15px_35px_rgba(94,48,133,0.04)] hover:-translate-y-0.5 hover:border-purple-200 cursor-pointer group relative z-10">
    <div className="flex items-center gap-4 mb-4 justify-start">
      <div className="w-10 h-10 bg-purple-50 text-[#5E3085] rounded-xl flex items-center justify-center font-bold text-sm shadow-sm shrink-0 transition-transform duration-500 group-hover:scale-105">
        {number}
      </div>
      <div className="text-[#5E3085] shrink-0 transition-colors duration-300 scale-110 md:scale-125 mr-1">{icon}</div>
      <h3 className="text-[#1A0B2E] font-bold text-xl text-right transition-colors duration-300 pr-1" style={{ fontFamily: "'El Messiri', sans-serif" }}>{title}</h3>
    </div>
    <p className="text-gray-500 text-sm leading-8 font-medium text-right transition-colors duration-300 group-hover:text-gray-800" style={{ fontFamily: "'Cairo', sans-serif" }}>{desc}</p>
  </div>
);

{/* أطقم الأيقونات الاحترافية المكبرة وفائقة النقاء */}
const GuestIcon = () => (
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.3" strokeLinecap="round" strokeLinejoin="round">
    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" />
  </svg>
);

const RegisterIcon = () => (
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.3" strokeLinecap="round" strokeLinejoin="round">
    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="22" y1="11" x2="16" y2="11" />
  </svg>
);

const LoginIcon = () => (
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" /><polyline points="10 17 15 12 10 7" /><line x1="15" y1="12" x2="3" y2="12" />
  </svg>
);

const FileIcon = () => (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.3" strokeLinecap="round" strokeLinejoin="round">
    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
    <polyline points="14 2 14 8 20 8" />
  </svg>
);

const SparkleIcon = () => (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.3" strokeLinecap="round" strokeLinejoin="round">
    <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z" />
  </svg>
);

const BoxIcon = () => (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.3" strokeLinecap="round" strokeLinejoin="round">
    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" />
    <path d="m7.5 4.21 4.5 2.6 4.5-2.6" />
    <path d="m3 8 9 5.19 9-5.19" />
    <path d="M12 13.19V21.5" />
  </svg>
);

const ContactIcon = () => (
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.3" strokeLinecap="round" strokeLinejoin="round">
    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 .8 2.81" />
  </svg>
);